# 🐐 Goat Repo Finder - Backend Environment Variables
# Copy this file to .env and fill in your values

# GitHub API token improves rate limiting and avoids search failures.
# Get one from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# Groq API key for AI explanation features.
# Get one from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Server port
PORT=5000

# Frontend URL for CORS (should match your frontend URL)
FRONTEND_URL=http://localhost:3000

# Rate limiting - max requests per 15 minutes per IP
RATE_LIMIT_MAX=100

# Node environment
NODE_ENV=development
